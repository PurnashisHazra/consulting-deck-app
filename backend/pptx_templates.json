{
  "schema_version": "1.0",
  "meta": {
    "description": "PPTX-friendly deterministic slide templates modeled from attached references",
    "coordinate_system": "absolute_px",
    "canvas": { "width": 1920, "height": 1080, "aspect_ratio": "16:9" },
    "defaults": {
      "font_family": "Verdana",
      "title_color": "#0b0f19",
      "body_color": "#0f172a",
      "accent_blue": "#142b6f",
      "accent_light_blue": "#5e95cf",
      "accent_teal": "#1fc0b8",
      "neutral_bg": "#f3f4f6",
      "surface_bg": "#eceef2",
      "safe_margin": 54
    }
  },
  "overflow_rules": {
    "title_max_lines": 2,
    "subtitle_max_lines": 2,
    "body_max_lines_per_block": 8,
    "bullet_max_count": 6,
    "auto_fit": {
      "min_font_size": 16,
      "line_height_scale_min": 1.05,
      "truncate_with_ellipsis": true,
      "secondary_action_if_overflow": "split_content_to_new_slide"
    }
  },
  "templates": [
    {
      "id": "source_description_application",
      "name": "Template - [type of slide]",
      "use_case": ["definition", "method", "taxonomy"],
